{
  "name": "unimart",
  "version": "0.1.0",
  "description": "Marketplace for students",
  "private": true,
  "author": "Daytech, Org.",
  "scripts": {
    "api:dev": "pnpm --filter @unimart/api dev",
    "web:dev": "pnpm --filter @unimart/web dev",
    "design-system:dev": "pnpm --filter @unimart/design-system dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "lint:dependencies": "knip --strict",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "keywords": [],
  "repository": {
    "type": "git",
    "url": "https://github.com/DayTech-Org/unimart.git"
  },
  "license": "ISC",
  "packageManager": "pnpm@10.17.0",
  "devDependencies": {
    "@biomejs/biome": "^2.3.15",
    "husky": "^9.1.7",
    "knip": "^5.83.1",
    "lint-staged": "^16.2.7",
    "rimraf": "^6.1.2",
    "turbo": "^2.8.7",
    "typescript": "catalog:"
  }
}
